APP_NAME="Production RAG Application"
DOCS_DIR=data
VECTOR_DB_DIR=artifacts/chroma
METRICS_DIR=artifacts/metrics
TRACES_DIR=artifacts/traces
EVALS_DIR=evals

# OpenRouter Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost:8501
OPENROUTER_APP_NAME=production-rag-app

# Retrieval & Reranker Configuration
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-base
CHUNK_SIZE=1200
CHUNK_OVERLAP=180
VECTOR_TOP_K=4
BM25_TOP_K=4
RERANK_TOP_K=2
MAX_CONTEXT_CHUNKS=2
MAX_OUTPUT_TOKENS=1200
TEMPERATURE=0
REQUEST_TIMEOUT=120

# Optional Cost Model Configuration (cost per 1M tokens)
INPUT_COST_PER_1M_TOKENS=0.00
OUTPUT_COST_PER_1M_TOKENS=0.00

# Langfuse Observability
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# Optional LangSmith Tracing
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=your_langsmith_project_name_here

# Evaluation Thresholds
EVAL_THRESHOLD_FAITHFULNESS=0.60
EVAL_THRESHOLD_ANSWER_RELEVANCE=0.60
EVAL_THRESHOLD_CONTEXT_PRECISION=0.60
EVAL_THRESHOLD_CITATION_COVERAGE=1.0
